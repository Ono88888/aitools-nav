# ── Notion ──────────────────────────────────────────────────
# 在 https://www.notion.so/my-integrations 创建 Integration 后获取
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的 Notion 工具数据库 ID（从数据库 URL 中复制，32位字母数字）
# 格式: https://notion.so/workspace/[DATABASE_ID]?v=xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的 Notion 用户数据库 ID
NOTION_USER_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的 Notion 日志数据库 ID（用于访问和点击统计）
NOTION_LOGS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的 Notion 搜索学习库 ID
NOTION_LEARN_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的 Notion 热门标签数据库 ID
NOTION_HOTKEYS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JWT 密钥（生产环境请务必修改）
JWT_SECRET=your_random_long_string_here

# Cloudflare Turnstile (人机验证)
# 在 https://dash.cloudflare.com/?to=/:account/turnstile 获取
NEXT_PUBLIC_TURNSTILE_SITE_KEY=xxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx

# ── 站点 ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=AI工具导航

# ── 广告（可选）──────────────────────────────────────────────
# Google AdSense Publisher ID（申请通过后填入）
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx
