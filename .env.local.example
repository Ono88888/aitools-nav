# ── Notion ──────────────────────────────────────────────────
# 在 https://www.notion.so/my-integrations 创建 Integration 后获取
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 你的 Notion 工具数据库 ID（从数据库 URL 中复制，32位字母数字）
# 格式: https://notion.so/workspace/[DATABASE_ID]?v=xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 站点 ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=AI工具导航

# ── 广告（可选）──────────────────────────────────────────────
# Google AdSense Publisher ID（申请通过后填入）
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx
