\",\"notification\":\"通知\"},\"teamAssets\":\"团队资产\",\"teamAssetsItems\":{\"creations\":\"作品\"},\"teamProfile\":\"团队主页\",\"terms\":\"使用条款\",\"tools\":\"工具\",\"toolsItems\":{\"imageToVideo\":\"图生视频\",\"img2videoUpgrade\":{\"button\":\"去看看\",\"title\":\"功能升级！一次最多可添加 10 帧\"},\"referenceToImage\":\"参考生图\",\"referenceToVideo\":\"参考生视频\",\"textToImage\":\"文生图片\",\"textToVideo\":\"文生视频\"}},\"task\":{\"action\":{\"addToMyRefNew\":\"一键将图片保存为主体\",\"cancel\":\"取消\",\"collect\":\"收藏\",\"collectSuccess\":\"已收藏，可在个人主页-收藏中查看\",\"continueCreate\":\"继续创作\",\"delete\":\"删除\",\"exitEdit\":\"退出编辑\",\"extend\":\"视频延长\",\"extendNew\":\"延长功能上线啦！最长可延长至5分钟\",\"frameExtraction\":\"抽帧\",\"imageEdit\":\"图片编辑\",\"mark\":\"标记\",\"quickEdit\":\"快速编辑\",\"quickEditDescription\":\"输入提示词智能编辑图片，轻松实现创意效果\",\"quickEditNew\":\"试试视频快捷编辑\",\"recreate\":\"重新编辑\",\"report\":\"反馈\",\"reprompt\":\"重新编辑\",\"share\":\"分享\",\"submit\":\"投稿\",\"submitted\":\"已投稿\",\"upscale\":\"画质增强\",\"videoEdit\":\"视频编辑\",\"videoQuickEditDescription\":\"输入提示词智能编辑视频，快速生成全新作品\"},\"allLoaded\":\"已加载全部内容\",\"empty\":\"开始创作您的第一个作品吧！\",\"emptyTutorial\":{\"character2video\":{\"message\":\"如何使用参考生视频\"},\"extension\":{\"message\":\"如何使用视频延长\",\"steps\":{\"step1\":{\"description\":\"从历史中选择或上传新视频\",\"title\":\"上传视频\"},\"step2\":{\"description\":\"可上传尾帧，输入延长描述\",\"title\":\"添加尾帧与提示词\"},\"step3\":{\"description\":\"选择模型和时长，生成新视频\",\"title\":\"选择模型并生成\"}}},\"faceSwap\":{\"message\":\"如何使用AI视频换脸\",\"steps\":{\"step1\":{\"description\":\"选择需替换人脸的视频\",\"title\":\"上传视频\"},\"step2\":{\"description\":\"提供想替换的清晰人脸照片\",\"title\":\"上传人像图\"},\"step3\":{\"description\":\"视频中的人脸自动替换\",\"title\":\"一键生成\"}}},\"imageEdit\":{\"message\":\"如何使用图片编辑\",\"steps\":{\"step1\":{\"description\":\"选择或上传图片\",\"title\":\"选择或上传图片\"},\"step2\":{\"description\":\"上传参考图，并输入编辑描述\",\"title\":\"添加参考图与提示词\"},\"step3\":{\"description\":\"设置时长、清晰度后，点击创作\",\"title\":\"调整设置并生成\"}}},\"img2video\":{\"message\":\"如何使用图生视频\"},\"lipSync\":{\"message\":\"如何使用视频对口型\",\"steps\":{\"step1\":{\"description\":\"上传含清晰人脸的短视频（1-120 秒）\",\"title\":\"上传视频素材\"},\"step2\":{\"description\":\"输入口播文字或上传音频\",\"title\":\"口播内容\"},\"step3\":{\"description\":\"文字需选音色、语速；上传音频可直接创作\",\"title\":\"完成设置并生成\"}}},\"musicVideo\":{\"message\":\"如何使用一键生成MV\",\"steps\":{\"step1\":{\"description\":\"上传1-7张图片作为素材\",\"title\":\"上传图片素材\"},\"step2\":{\"description\":\"上传音频素材\",\"title\":\"上传音频\"},\"step3\":{\"description\":\"设置视频宽高比、清晰度，支持上传字幕，开始生成\",\"title\":\"完成设置并生成\"}}},\"oneClickVideoProduction\":{\"message\":\"如何使用一键成片\",\"steps\":{\"step1\":{\"description\":\"上传1-7张图片作为素材\",\"title\":\"上传图片素材\"},\"step2\":{\"description\":\"支持选择通用或电商广告场景\",\"title\":\"输入提示词，选择创作场景\"},\"step3\":{\"description\":\"设置视频比例及时长，开始生成\",\"title\":\"完成设置并生成\"}}},\"upscale\":{\"message\":\"如何使用视频增强\",\"steps\":{\"step1\":{\"description\":\"选择你想要增强的视频\",\"title\":\"选择或上传视频\"},\"step2\":{\"description\":\"可选1080p、2K或4K\",\"title\":\"选择目标清晰度\"},\"step3\":{\"description\":\"生成所选画质的高清视频\",\"title\":\"生成增强视频\"}}},\"upscale_image\":{\"message\":\"如何使用图片增强\",\"steps\":{\"step1\":{\"description\":\"选择或上传图片\",\"title\":\"选择或上传图片\"},\"step2\":{\"description\":\"选择目标清晰度\",\"title\":\"选择目标清晰度\"},\"step3\":{\"description\":\"生成所选画质的高清图片\",\"title\":\"生成增强图片\"}}},\"videoEdit\":{\"message\":\"如何使用视频编辑\",\"steps\":{\"step1\":{\"description\":\"选择或上传视频\",\"title\":\"选择或上传视频\"},\"step2\":{\"description\":\"添加参考图与提示词\",\"title\":\"添加参考图与提示词\"},\"step3\":{\"description\":\"设置宽高比、时长后，点击创作\",\"title\":\"调整设置并生成\"}}},\"videoRemake\":{\"message\":\"如何使用视频复刻\",\"steps\":{\"step1\":{\"description\":\"上传想要复刻的视频素材\",\"title\":\"上传视频素材\"},\"step2\":{\"description\":\"上传想要复刻的素材图片\",\"title\":\"上传图片素材\"},\"step3\":{\"description\":\"根据原视频风格生成新视频\",\"title\":\"生成复刻视频\"}}}},\"extendNotForUpacale\":\"画质增强后的视频暂不支持延长\",\"extendOnly1080p\":\"仅1080p可用\",\"filterProcessing\":\"进行中\",\"processingEmpty\":\"所有任务已完成，太棒了！\",\"prompt\":{\"placeholder\":\"无提示词\"},\"status\":{\"auditAudioFailed\":{\"content\":\"此音频内容不符合平台审核标准，已被移除\",\"title\":\"音频已下架\"},\"auditImageFailed\":{\"content\":\"此图片内容不符合平台审核标准，已被移除\",\"title\":\"图片已下架\"},\"auditVideoFailed\":{\"content\":\"此内容不符合平台审核标准，已被移除\",\"title\":\"内容已下架\"},\"canceled\":{\"content\":\"任务取消成功，积分已退回\",\"title\":\"任务已取消\"},\"checkFailed\":{\"content\":\"您的描述或者图片可能违反了我们的内容政策，请修改后重试。\",\"title\":\"生成失败\"},\"creating\":{\"title\":\"生成中\"},\"empty\":{\"content\":\"此内容已被删除\",\"title\":\"已删除\"},\"hevcNotSupported\":{\"content\":\"视频生成成功，但当前浏览器似乎不支持 HEVC (H.265) 编码格式。\\n建议您尝试使用 Chrome 浏览器，或将视频下载后转换为 H.264 格式查看。\\n后续生成时，您可以选择 H.264 选项以避免此问题。\",\"helpButton\":\"无法播放？\"},\"otherFailed\":{\"content\":\"生成失败，积分已退回，请稍后重试。\",\"title\":\"生成失败\"},\"queue\":{\"free\":\"\u003cbutton\u003e订阅套餐\u003c/button\u003e以提升生成速度\",\"hours\":\"小时\",\"imgVip\":\"已将您的任务加入到VIP队列。\",\"minutes\":\"分钟\",\"nopeak\":\"当前平台使用人数激增，系统算力承载压力较大，请耐心等待。如您希望快速生成，建议使用积分创作。\",\"nopeakAudio\":\"任务将排队等待流量低峰时执行，请耐心等待。\",\"title\":\"排队中\",\"upgrade\":\"订阅套餐\",\"vip\":\"已将您的任务加入到VIP队列。\",\"vipAudio\":\"已将您的任务加入到VIP队列。\",\"waitLessThanOneMinute\":\"预计等待少于1分钟\",\"waitMoreThan\":\"预计等待{min}{unit}以上\",\"waitMoreThanProlonged\":\"需求量增多，预计等待{min}{unit}以上，感谢您耐心等待\",\"waitTime\":\"预计等待{min}-{max}{unit}\",\"waitTimeProlonged\":\"需求量增多，预计等待{min}-{max}{unit}，感谢您耐心等待\"}},\"toTop\":\"回到顶部\"},\"teamInvite\":{\"actions\":{\"apply\":\"申请加入\",\"back\":\"返回\",\"loginAndApply\":\"登录后申请\",\"ok\":\"好的\",\"switchToPersonal\":\"一键切换到个人空间\",\"unavailable\":\"暂不可加入\",\"waiting\":\"已申请加入，等待管理员审核\"},\"loading\":\"加载中...\",\"states\":{\"apply\":{\"description\":\"欢迎加入 {teamName} 团队版！在团队空间中，你可以创建、删除、查看作品，团队资产可在成员间共享，让协作更高效。\",\"title\":\"申请加入 {teamName} 的工作区\"},\"approved\":{\"description\":\"你已通过审核，点击“好的”即可切换到该团队空间。\",\"title\":\"恭喜您加入 {teamName} 的团队\"},\"full\":{\"description\":\"当前团队已达到人数上限，请联系管理员处理。\",\"title\":\"团队人数已满\"},\"invalid\":{\"description\":\"该邀请链接不可用，请联系管理员重新获取邀请链接。\",\"title\":\"邀请链接已失效\"},\"needSwitchSelf\":{\"description\":\"你当前处于团队空间，请先切换到个人空间后再申请加入。\",\"title\":\"请先切换到个人空间\"},\"pending\":{\"description\":\"你的加入申请已发送，请等待管理员审核。\",\"title\":\"申请加入 {teamName} 的工作区\"},\"rejected\":{\"description\":\"当前账号暂不可加入该团队，请联系团队管理员。\",\"title\":\"暂不可加入该团队\"}}},\"teamProfile\":{\"actions\":{\"approve\":\"通过\",\"deny\":\"拒绝\",\"edit\":\"编辑\",\"remove\":\"移除\",\"removeConfirmDescription\":\"是否确认将 {name} 移出团队？\",\"removeConfirmTitle\":\"确认移除成员\"},\"cards\":{\"inviteLink\":{\"copyLink\":\"复制链接\",\"descriptionHighlight\":\"该链接\",\"descriptionPrefix\":\"分享专属邀请链接，邀请他人加入当前工作区。你可以随时禁用或重置\",\"descriptionSuffix\":\"\",\"title\":\"邀请链接\",\"toggleAriaLabel\":\"启用邀请链接\"},\"inviteOnly\":{\"description\":\"只有通过邀请链接或邮件邀请的用户才能加入当前工作区\",\"title\":\"仅限受邀成员加入\"}},\"credits\":{\"allocate\":{\"batchPlaceholder\":\"请输入每人分配的积分数量\",\"exceedTip\":\"分配额度超过团队剩余可分配积分\",\"placeholder\":\"请输入积分数量\",\"tip\":\"团队剩余可分配积分数：{count}\",\"title\":\"分配积分\"},\"batch\":{\"deductExceedTip\":\"部分成员剩余积分不足，无法扣除\",\"selected\":\"已选 {count} 个成员\"},\"configButton\":\"积分分配\",\"deduct\":{\"batchPlaceholder\":\"请输入每人扣除的积分数量\",\"fillAll\":\"全部回收\",\"placeholder\":\"请输入回收积分数量\",\"tip\":\"该成员剩余积分数：{count}\",\"title\":\"积分回收\"},\"deductButton\":\"积分回收\",\"deductError\":\"回收积分必须小于等于成员剩余可用积分数\",\"insufficient\":\"积分不足，请联系客户经理充值\",\"search\":{\"placeholder\":\"搜索账号\"},\"summary\":{\"consumed\":\"消耗积分数\",\"remaining\":\"剩余积分数\",\"teamRemaining\":\"企业剩余可分配积分数\"},\"table\":{\"headers\":{\"consumed\":\"消耗积分数\",\"remaining\":\"剩余积分数\"}},\"toolbar\":{\"batchAllocate\":\"批量分配\",\"batchDeduct\":\"批量回收\"}},\"empty\":\"暂无成员\",\"loading\":\"加载中...\",\"personalWorkspace\":\"个人工作区\",\"setting\":{\"displayName\":{\"description\":\"设置团队名称在 Vidu 中的展示方式\",\"title\":\"显示名称\"}},\"state\":{\"applying\":\"申请中\",\"joined\":\"已加入\",\"unknown\":\"未知\"},\"switchToPersonalWorkspace\":\"切换到个人工作区\",\"switchToWorkspace\":\"切换到{name}的工作区\",\"table\":{\"headers\":{\"action\":\"操作\",\"joinDate\":\"加入时间\",\"members\":\"成员\",\"state\":\"状态\",\"type\":\"类型\"}},\"tabs\":{\"credits\":\"积分\",\"members\":\"成员\",\"setting\":\"设置\"},\"type\":{\"admin\":\"管理员\",\"member\":\"成员\",\"unknown\":\"未知\"},\"workspaceFallback\":\"团队工作区\",\"workspaceTitleWithName\":\"{name}的工作区\",\"workspaceWithName\":\"{name}的工作区\",\"you\":\"(你)\"},\"template\":{\"prompt\":\"提示词\"},\"templates\":{\"all\":\"全部\",\"button\":\"创作\",\"changeTemplate\":\"切换模板\",\"errorMessage\":\"该分类已被删除\",\"inspiration\":\"灵感\",\"noTemplates\":\"暂无内容\",\"notFound\":\"该模板暂时无法使用，换一个试试吧~\",\"pickFromGallery\":\"可选素材\",\"search\":{\"noResults\":\"没有匹配的内容\",\"placeholder\":\"输入模板名称\"},\"title\":\"AI模板\",\"tour\":{\"templatePanel\":\"这里可以切换模板哦\",\"uploadImage\":\"上传图片，立即开始创作吧\"},\"viewDetails\":\"查看灵感\"},\"text2audio\":{\"autoAdjustDuration\":\"已自动调整总时长以获得最佳效果\",\"create\":{\"noPrompt\":\"请输入文字描述\",\"outOfCredit\":\"别让灵感等太久，充个积分继续冲！\",\"promptNoTimeTag\":\"请将每段描述词与时间戳进行匹配，生成质量更佳，如 01s-04s: raining\",\"timestampOutOfRange\":\"请保持时间戳时刻范围在总时长范围内\",\"timestampOverTip\":\"时间戳可能过多，保持5个以内效果最佳哦\",\"timeTagNoPrompt\":\"部分时间戳缺少提示词，请补充提示词或删除时间戳～\"},\"description\":\"精准控制总时长、及每段音效起始时间，还可多段叠加\",\"freeTrial\":\"免费试用\",\"freeTrialLeft\":\"剩余{time}次\",\"timelineEditor\":{\"fillPrompt\":\"添加时间戳\",\"intervalTooShort\":\"时间间隔大于{limit}s效果更佳\",\"title\":\"设置总时长\"},\"timestampTextArea\":{\"endTimeEqualZero\":\"结束时间需至少大于1s\",\"endTimeOverEarlierTime\":\"结束时间不能早于开始时间\",\"invalidCharacter\":\"暂不可输入符号～\",\"placeholder\":\"🎧 描述声音和时间段，立马生成你的专属音效！如 [01-04s] 雨滴落在屋顶上～\",\"sample\":\"示例\",\"segmentLimitExceeded\":\"精简提示词效果更佳，建议不超过{limit}个字符～\",\"startTimeLaterEndTime\":\"开始时间不能晚于结束时间\",\"startTimeOverDuration\":\"开始时间需在{limit}秒以内\",\"timestamp\":\"时间戳\",\"timestampLimit\":\"当前仅支持{limit}s内的时间戳哦～\",\"timestampTip\":\"时间戳：精确到秒地控制不同声音片段的起始点、结束点与时长区间\",\"tips\":\"tips\",\"totalLimitExceeded\":\"精简提示词效果更佳，建议不超过{limit}个字符～\"},\"title\":\"AI音效\",\"userGuide\":\"用户指南\"},\"tools\":{\"after\":\"使用后\",\"before\":\"原素材\",\"example\":\"示例\",\"faceSwap\":{\"description\":\"视频人脸一键替换，轻松打造全新形象\",\"sourceImage\":{\"label\":\"你的照片\"},\"title\":\"视频换脸\"},\"historyCreation\":\"历史作品\",\"languageOptions\":{\"auto\":\"自动\",\"en\":\"英文\",\"zh\":\"中文\"},\"lipSync\":{\"description\":\"上传视频素材，输入文本或音频，生成对口型语音视频\",\"input\":{\"audioHelper\":\"支持 MP3、WAV、AAC、M4A 格式，时长 1-120 秒\",\"audioMode\":\"音频上传\",\"label\":\"口播内容\",\"labelTooltip\":\"说明：\\n1. 文字内容不少于 4 个字符，不超过 1200 个字符（2–600 个汉字或 4–1200 个英文）；\\n2. 支持文本录入或音频；\\n3. 停顿控制：支持自定义文本之间的语音时间间隔。使用方式：在文本中增加 \u003c#x#\u003e 标记，x 为停顿时长（单位：秒），范围 [0.01, 99.99]，最多保留两位小数，不可连续使用多个停顿标记；\\n4. 停顿示例：你好\u003c#2#\u003e我是vidu\u003c#2#\u003e很高兴见到你。\",\"labelTooltipAria\":\"查看口播内容说明\",\"textMode\":\"文字录入\",\"textPlaceholder\":\"输入你希望视频人物说出的文字内容...\"},\"settings\":{\"speed\":\"语速\",\"taskTagSpeed\":\"语速 {speed}\",\"voice\":\"音色\",\"volume\":\"自定义音量\"},\"submit\":{\"disabledInvalidText\":\"文字内容需在 4-2000 字符之间\",\"disabledMissingAudio\":\"请先上传一段音频\",\"disabledMissingVideo\":\"请先上传一段视频\",\"disabledMissingVoice\":\"请先选择音色\"},\"title\":\"视频对口型\",\"videoUpload\":{\"helper\":\"建议上传正面真人人脸画面 / 五官与真人比例相近的卡通人物，支持时长 1-120 秒，大小不超过500M\",\"label\":\"视频素材\",\"labelTooltip\":\"说明：\\n1.视频内容免涉肖像权，否则会被下架或销毁\\n2.视频素材的规范性要求：人脸画面：要求真人出镜（如果是卡通人物，需人物五官和真人比例相近），画面中的人脸说话时，建议正对镜头，水平转动不超过45度，俯仰不超过15度；人脸尽量不遮挡，面部光线稳定。\",\"labelTooltipAria\":\"查看视频素材说明\"}},\"oneClickMv\":{\"audioUpload\":{\"helper\":\"请上传带歌词的音乐，支持MP3/WAV/AAC/M4A格式，时长10-180s\",\"label\":\"音频素材\"},\"description\":\"上传素材输入提示词，一键生成音乐视频\",\"imageUpload\":{\"helper\":\"建议上传模特或风格图片，图片数量1-7张，支持PNG/JPEG/JPG/WebP，单张不超过50M\"},\"prompt\":{\"label\":\"提示词\",\"placeholder\":\"选填，补充你希望 MV 呈现的风格、镜头或氛围\"},\"submit\":{\"disabledMissingAudio\":\"请先上传一段音频\",\"disabledMissingImages\":\"请先上传至少 1 张图片\"},\"subtitle\":{\"invalidSizeWithLimit\":\"字幕文件大小超过限制（最大 {limit}），请重新上传\",\"invalidType\":\"仅支持上传 .srt 字幕文件\"},\"title\":\"一键生成 MV\"},\"oneClickVideoProduction\":{\"aspectRatio\":{\"label\":\"视频比例\"},\"description\":\"上传图片输入提示词，一键生成风格化视频\",\"duration\":{\"label\":\"输出时长\"},\"lang\":{\"en\":\"英文\",\"label\":\"配音\",\"zh\":\"中文\"},\"prompt\":{\"label\":\"提示词\",\"placeholder\":\"描述你想要的视频效果\"},\"scenario\":{\"ecommerce_ad\":{\"description\":\"适配电商广告场景，助力营销创作\",\"label\":\"电商广告\"},\"general\":{\"descriptio