ngToast\":\"正在思考中，请稍候\"},\"chatSettings\":{\"upgrade\":\"升级\"},\"clawOnline\":\"Vidu Claw 现已上线！\",\"collapse\":\"收起\",\"contentType\":{\"audio\":\"音频\",\"image\":\"图片\",\"plan\":\"计划\",\"script\":\"分镜脚本\",\"video\":\"视频\"},\"create\":\"创建\",\"createByAgent\":\"由 \u003cspan\u003eVidu Agent\u003c/span\u003e 生成\",\"createContextByAgent\":\"\u003cspan\u003eVidu Agent\u003c/span\u003e 结合上下文理解\",\"creditDeducted\":\"本次消耗\u003cspan\u003e{credits}\u003c/span\u003e \u003coriginCredits\u003e{total}\u003c/originCredits\u003e\",\"creditInfo\":\"\u003cspan\u003e{credits}\u003c/span\u003e \u003coriginCredits\u003e{total}\u003c/originCredits\u003e\",\"demo\":\"示例\",\"dialogAction\":{\"copy\":\"复制\",\"location\":\"定位至画布对应区域\",\"quote\":\"引用\"},\"dialogSettingsTip\":{\"scene\":\"切换创作场景\",\"settings\":\"调整创作设置\"},\"editInClip\":{\"back\":\"返回\",\"backgroundMusic\":\"背景音乐\",\"overLimit\":\"已超出最多分镜\",\"recreate\":\"重新生成\",\"recreating\":\"正在为您重新生成\",\"submit\":\"生成成片\",\"voiceover\":\"旁白\",\"volume\":\"音量\"},\"error\":{\"createCanvasFailed\":\"创建画布失败\",\"createChatFailed\":\"创建对话失败\",\"createProjectFailed\":\"创建项目失败\",\"getCanvasDetailFailed\":\"获取画布详情失败\",\"getProjectDetailFailed\":\"获取项目详情失败\",\"getVideoGroupClipsFailed\":\"获取分镜节点失败\",\"recreateTtsFailed\":\"重新生成音频失败\",\"storyboardItemEmpty\":\"分镜内容不能为空\"},\"expand\":\"展开\",\"failed\":\"任务失败\",\"freeLimited\":\"限时免费\",\"freeProjectTag\":\"免费\",\"gender\":{\"female\":\"女性\",\"male\":\"男性\"},\"inputNode\":{\"title\":\"我的创作素材\"},\"internetSearch\":{\"tip\":\"联网搜索\",\"title\":\"联网搜索\"},\"invite\":{\"expandTitle\":\"邀请好友，获得免费项目\",\"shrinkTitle\":\"邀请好友\",\"ultimateShrinkTitle\":\"免费项目\"},\"library\":{\"input\":\"输入\",\"introduce\":\"介绍\",\"title\":\"案例\",\"use\":\"使用\"},\"loading\":\"加载中...\",\"modelSelect\":{\"tip\":\"添加人物特征\",\"title\":\"人物特征\"},\"myProject\":{\"allProjects\":\"所有项目\",\"seeAll\":\"查看全部\",\"title\":\"项目\"},\"noMore\":\"没有更多了\",\"noRecord\":\"暂无内容\",\"operationSelect\":{\"add_to_chat\":\"添加到对话\",\"copy\":\"复制\",\"download\":\"下载\",\"edit_in_clip\":\"编辑分镜\",\"error\":\"操作失败\",\"generate_same\":\"重新生成\",\"generate_video\":\"生成视频\",\"QuotaExceededError\":\"任务数量已达上限，完成当前任务后再试\",\"try_again\":\"重试\"},\"partner\":\"你的专业视频创作伙伴\",\"project\":{\"newProject\":\"新建项目\",\"renameSuccess\":\"重命名成功\"},\"scene\":{\"common\":{\"dialogTitle\":\"通用创作\",\"tip\":\"适配各类常规场景，创作更灵活\",\"title\":\"通用创作\"},\"e_commerce\":{\"dialogTitle\":\"电商广告视频创作\",\"tip\":\"适配电商广告场景，助力营销内容高效生成\",\"title\":\"电商广告\"},\"remake\":{\"dialogTitle\":\"视频复刻创作\",\"tip\":\"上传参考视频，快速生成结构风格相似的新视频\",\"title\":\"视频复刻\"}},\"sceneSelect\":{\"tip\":\"选择创作场景\",\"title\":\"场景\"},\"scriptNode\":{\"aside\":\"旁白\",\"duration\":\"时长\",\"lens\":\"分镜\",\"prompts\":\"提示词\",\"shot\":\"分镜{number}\",\"stage\":{\"1\":\"第一幕\",\"2\":\"第二幕\",\"3\":\"第三幕\",\"4\":\"第四幕\",\"5\":\"第五幕\",\"6\":\"第六幕\",\"7\":\"第七幕\",\"8\":\"第八幕\",\"9\":\"第九幕\",\"10\":\"第十幕\",\"11\":\"第十一幕\",\"12\":\"第十二幕\",\"13\":\"第十三幕\",\"14\":\"第十四幕\",\"15\":\"第十五幕\"},\"storyboard\":\"剧情板\",\"title\":\"分镜脚本\"},\"simpleProjectTips\":{\"button\":\"升级\",\"create\":\"创建项目\",\"disabledTip\":\"当前为只读模式，仅限查看；请新建项目以执行操作\",\"invitedButton\":\"立即邀请\",\"invitedTip\":\"邀请好友，获得免费项目\",\"title\":\"只读模式，升级后可编辑\"},\"skill\":{\"generateScript\":\"营销脚本大师\",\"title\":\"可尝试脚本技能\"},\"subtitle\":\"一键生成15-30秒多镜头带配音视频\",\"switchSuccess\":\"切换成功\",\"try\":\"试试\",\"userInfo\":{\"creditsDetails\":\"积分详情\"},\"videoNode\":{\"failedToast\":\"Oops，成片生成失败，您可以在分镜板中免费修改失败分镜后重新生成。\",\"history\":\"历史\"},\"voiceLanguage\":{\"all\":\"全部\",\"ar\":\"阿拉伯语\",\"cs\":\"捷克语\",\"de\":\"德语\",\"el\":\"希腊语\",\"en\":\"英文\",\"es\":\"西班牙语\",\"fi\":\"芬兰语\",\"fr\":\"法语\",\"hi\":\"印地语\",\"id\":\"印尼语\",\"it\":\"意大利语\",\"ja\":\"日语\",\"ko\":\"韩语\",\"nl\":\"荷兰语\",\"pl\":\"波兰语\",\"pt\":\"葡萄牙语\",\"ro\":\"罗马尼亚语\",\"ru\":\"俄语\",\"th\":\"泰语\",\"tr\":\"土耳其语\",\"uk\":\"乌克兰语\",\"vi\":\"越南语\",\"zh\":\"中文\"},\"voiceSelect\":{\"auto\":\"智能配音\",\"autoTooltip\":\"根据提示词自动匹配合适音色\",\"selected\":\"已选择\",\"shareTitle\":\"音色\",\"tip\":\"选择旁白音色\",\"tipTooltip\":\"请挑选合适的音色用于旁白配音\",\"title\":\"旁白音色选择\"},\"warning\":{\"nameConflict\":\"名称已存在，请重新输入\",\"nameRequiredFile\":\"项目名称不能为空\"},\"welcome\":{\"enterThoughts\":\"输入你的想法\",\"hi\":\"你好，{name}\",\"title\":\"如何使用\",\"viewAll\":\"查看全部\",\"welcomeTip\":\"今天我们创作什么？\"},\"welcomeGuide\":{\"step1\":\"选定对应场景，输入产品图或提示词即可开始创作\",\"step2\":\"AI助手将自动设计分镜与旁白，你可随时修改\",\"step3\":\"进入画布编辑区，可对内容进行更灵活的调整与操作\"}},\"ai-image-generator\":{\"buttons\":{\"generateNow\":\"立即生成\"},\"faq\":{\"q1\":{\"description\":\"Vidu 在生成一致性、速度与成品质量上表现突出，并在编辑控制、角色保持等多项测试中优于主流模型。\",\"title\":\"Vidu 与其他 AI 图片工具有何不同？\"},\"q2\":{\"description\":\"支持。Vidu 可同时处理最多 7 张参考图片，即使内容复杂，也能保持画面结构、角色与风格的高度一致。\",\"title\":\"是否支持多张参考图？\"},\"q3\":{\"description\":\"可以。Vidu 支持对已生成的图片进行调整，包括修改尺寸、分辨率与模型效果，并可自由添加、移除或替换物体、背景、服饰等元素。让你能够高效优化内容，适配不同用途，无需重新生成。\",\"title\":\"生成后可以继续编辑图片吗？\"},\"q4\":{\"description\":\"写实、动漫、漫画、电影感、产品渲染、中国水墨画等。\",\"title\":\"支持哪些风格？\"},\"q5\":{\"description\":\"适合。凭借 2K/4K 高清输出与快速渲染能力，Vidu 专为实际生产场景设计，可用于营销推广、广告设计、视觉创作及影视预演等领域。\",\"title\":\"是否适合商业用途？\"},\"title\":\"常见问题\"},\"imageEditing\":{\"description\":\"图片生成后，仍可随时使用内置 AI 编辑功能进行修改，轻松满足最终交付需求。\",\"features\":{\"editContent\":{\"description\":\"在图片中添加、移除或修改任意元素。\",\"title\":\"内容编辑\"},\"resize\":{\"description\":\"灵活适配不同平台、版式与画面比例。\",\"title\":\"调整尺寸\"},\"upscale\":{\"description\":\"让图片更清晰，方便发布、分享或交付。\",\"title\":\"提升分辨率\"}},\"title\":\"AI 图片编辑\"},\"referenceToImage\":{\"description\":\"上传一张或多张参考图，并告诉模型需要保留哪些部分、调整哪些内容，或融合哪些特征。\",\"features\":{\"anyStyle\":{\"description\":\"皆能生成极具美学质感的图像，涵盖动漫、照片级真实感、广告设计、艺术视觉等多种风格与场景。\",\"title\":\"不论何种风格、何种用途\"},\"mergeElements\":{\"description\":\"将多张参考图中的元素自然融合为一张图片。\",\"title\":\"多元素融合\"},\"superConsistency\":{\"description\":\"在多次生成中保持角色、物体与风格稳定统一。\",\"title\":\"超强一致性\"}},\"title\":\"参考生图\"},\"step\":{\"step1\":{\"description\":\"选择文生图片或参考生图。\",\"title\":\"选择模式\"},\"step2\":{\"description\":\"文生图片：直接描述你想要的画面或风格。参考生图：上传参考图并补充文字说明。\",\"title\":\"输入描述或上传图片\"},\"step3\":{\"description\":\"选择分辨率、尺寸与数量，点击创作按钮。之后仍可编辑：调整尺寸、优化细节或提升分辨率。\",\"title\":\"设置参数并生成\"},\"title\":\"如何使用 Vidu AI 生成图片\"},\"subtitle\":\"将文字或参考图转化为高清图片，轻松获得风格统一、细节丰富的作品——支持自由变换风格、融合多种元素；生成后可随时编辑，调整尺寸、优化细节并提升画质。\",\"textToImage\":{\"description\":\"只需描述你想要的画面——主体、风格、光线、氛围、拍摄视角——即可在几秒内获得高质量图片。\",\"features\":{\"anySize\":{\"description\":\"支持任意比例，适用于广告、产品图、海报、社交媒体等多种场景。\",\"title\":\"尺寸自定义\"},\"fastGeneration\":{\"description\":\"短短数秒即可呈现结果，最快5秒出图，助你高效创作。\",\"title\":\"快速生成\"},\"ultraHd\":{\"description\":\"支持 1080p、2K、4K 分辨率，细节清晰、画面干净。\",\"title\":\"高清输出\"}},\"title\":\"文生图片\"},\"title\":\"AI 生图与编辑器\",\"whyChoose\":{\"advantages\":{\"consistency\":{\"description\":\"确保每一次生成的风格与主体都保持连贯。\",\"title\":\"输出稳定一致\"},\"editing\":{\"description\":\"无需切换工具，即可调整尺寸、优化细节并提升分辨率。\",\"title\":\"AI 编辑\"},\"imageToVideo\":{\"description\":\"轻松将静态图片转化为动态视频。\",\"title\":\"一键图片转视频\"},\"ultraHd\":{\"description\":\"专为呈现清晰、专业的视觉效果而生。\",\"title\":\"高清画质（1080p/2K/4K）\"}},\"title\":\"为什么选择 Vidu AI 图片生成器\"}},\"ai-image-to-video\":{\"advantage\":{\"cinematicQuality\":{\"description\":\"让你的图片呈现出清晰锐利的细节与明亮生动的色彩。每一帧都像真实电影画面般细腻沉浸，视觉表现更具质感与张力。\",\"title\":\"电影级高清画质\"},\"diverseStyles\":{\"description\":\"支持多种动画风格选择，让图片以自然方式动起来。无论是轻微变化还是强烈运动，画面都能顺畅过渡、流畅呈现，轻松将图片转化为视频体验。\",\"title\":\"多样动态风格，随心驱动动画\"},\"expressiveMotion\":{\"description\":\"动作从细腻的微表情到大幅度的变化都能自然衔接，节奏流畅连贯。每一个动作都紧密相连，让画面更生动、更易理解，也更具故事感。\",\"title\":\"富有表现力的动态运动\"}},\"buttons\":{\"generateNow\":\"立即生成\"},\"cta\":{\"button\":\"立即生成\",\"ctaTitle\":\"立即开启图生视频创作\",\"title\":\"Vidu AI 图生视频\"},\"faq\":{\"q1\":{\"description\":\"AI 图生视频可以将一张静态图片转化为动态视频。只需上传图片并输入提示词，AI 就会自动生成流畅的电影级运动效果，在保持画面细节一致的同时，让静态视觉变成更具表现力的视频内容。\",\"title\":\"什么是 AI 图生视频？它是如何工作的？\"},\"q2\":{\"description\":\"可以。像 Vidu 这样的工具支持你对画面运动进行引导，包括主体动作、镜头运动，甚至可以设置首帧与尾帧，让生成结果更加可控、稳定且自然。\",\"title\":\"在图生视频中可以控制运动效果吗？\"},\"q3\":{\"description\":\"无论是照片、插画、动漫、手绘草图还是数字艺术作品，都可以使用。系统会在保留原有风格的基础上，为画面添加自然流畅的动态效果。\",\"title\":\"图生视频支持哪些类型的图片？\"},\"q4\":{\"description\":\"建议使用清晰度高、主体明确、光线良好的图片。同时保持提示词简洁聚焦，避免过多指令，从而减少画面跳动或不自然的情况。\",\"title\":\"如何提升图生视频的生成效果？\"},\"q5\":{\"description\":\"重点描述\\\"如何运动\\\"，而不是重复画面内容。可以加入镜头运动（如平移、推进、跟随等），并使用简单结构：主体动作 + 镜头运动 + 场景变化 + 风格描述，这样更容易生成电影感效果。\",\"title\":\"如何编写图生视频的运动提示词？\"},\"q6\":{\"description\":\"当你只需要单张图片生成简单动态时，使用「图生视频」即可；当你需要角色一致性、多场景叙事或复杂故事表达时，建议使用「参考生视频」。在实际创作中，两者也可以结合使用：简单片段用图生视频，复杂故事用参考生视频。\",\"title\":\"什么时候使用「参考生视频」，什么时候使用「图生视频」？\"},\"title\":\"图生视频常见问题解答\"},\"feature\":{\"firstAndLast\":{\"description\":\"只需设定首帧与尾帧，图生视频即可自动生成自然流畅的过渡动画，让画面之间的运动衔接更加顺滑，所有元素保持稳定不偏移。无论是照片、手绘还是数字艺术作品，都能轻松适配。\",\"title\":\"首尾帧控制\"}},\"mistakes\":{\"lowQualitySource\":{\"description\":\"如果输入图片模糊或分辨率较低，生成的视频也会变得不清晰，细节容易丢失，画面运动可能显得粗糙。建议使用清晰、光线充足的图片，这样生成结果会更干净、更稳定。\",\"title\":\"低质量素材图片\"},\"overloadedPrompt\":{\"description\":\"在一个提示词中加入过多指令，可能会让运动逻辑变得混乱，导致画面不自然或跳动感明显。建议保持描述简洁，专注于一个核心动作或主要表达方向。\",\"title\":\"动作提示过于复杂\"},\"smallSubject\":{\"description\":\"当画面中的主体过小或不够突出时，AI 可能无法准确识别重点，导致运动效果杂乱。建议确保主体在画面中占据足够比例，并保持清晰可见，让动作生成更准确自然。\",\"title\":\"主体过小或不清晰\"},\"title\":\"图生视频常见问题与优化建议\"},\"nextLevel\":{\"title\":\"全新升级的图生视频体验\"},\"step\":{\"step1\":{\"description\":\"点击「Try Vidu」进入操作界面，选择「图生视频」。上传第一张图片作为起始画面，如果需要，也可以再添加第二张图片作为结束画面，用于生成更完整的动态过渡效果。\",\"title\":\"选择「图生视频」功能\"},\"step2\":{\"description\":\"在输入框中描述你希望画面如何运动与呈现。你也可以参考使用指南中的建议，优化提示词表达，让生成效果更符合预期。\",\"title\":\"输入生成提示词\"},\"step3\":{\"description\":\"根据需求设置视频时长、分辨率以及运动强度。如果需要生成多个版本，可以通过数量选项进行调整。设置完成后点击 Create，即可开始生成视频。\",\"title\":\"调整输出参数并生成\"},\"title\":\"如何将图片转化为视频\"},\"styles\":{\"anime\":{\"title\":\"日漫\"},\"description\":\"将任意图片转化为你想要的视频风格，无论是照片、动漫、手绘草图还是绘画作品，都能轻松适配。Vidu 会保持画面风格一致，并让整体运动更加自然流畅。\",\"illustration\":{\"title\":\"插画\"},\"realistic\":{\"title\":\"现实风格\"},\"surreal\":{\"title\":\"超现实\"},\"title\":\"多风格图生视频\"},\"subtitle\":\"通过 AI 图生视频功能，让静态图片自然动起来。上传你的图片，描述想要的运动方式，Vidu 就能在几秒内生成具有电影感的视频，画面动作流畅、细节一致，整体呈现专业级效果。\",\"title\":\"AI 图生视频\",\"useCase\":{\"memories\":{\"description\":\"为老照片或家庭影像添加轻柔、真实的动态效果，让静态记忆重新拥有情感温度，更适合用于故事记录或纪念表达。\",\"title\":\"唤醒旧时回忆\"},\"productVideos\":{\"description\":\"让产品图片自然\\\"活\\\"起来，通过流畅的动态效果与简洁的电影式转场，把单张产品图变成更具吸引力的视频内容，特别适用于电商展示与广告投放。\",\"title\":\"制作产品视频\"},\"professionalShorts\":{\"description\":\"将概念设计、情绪板或角色设定轻松转化为短篇电影感视频。Vidu 会保持画面风格统一与质感稳定，让故事表达更清晰流畅，非常适合影视创作者、动画设计师与创意团队使用。\",\"title\":\"打造专业短片\"},\"socialMedia\":{\"description\":\"将自拍、人像或数字艺术作品转化为更具吸引力的视频内容。无需复杂操作，即可快速生成适合 Reels、TikTok 或 Story 的动态内容，让你的作品在静态信息流中更突出、更有生命力。\",\"title\":\"在社交媒体脱颖而出\"},\"title\":\"用图生视频，让任何图片都\\\"动\\\"起来\"}},\"ai-reference-to-video\":{\"advantage\":{\"flexibleReferenceCreation\":{\"description\":\"你可以自行创建参考素材，也可以从参考库中直接选用。每个参考都可以提取来源图片或视频中的角色、风格、构图、镜头运动、场景以及特效等信息，让创作更加可控。\",\"title\":\"灵活的参考创建\"},\"moreCharacters\":{\"description\":\"支持同时使用最多 7 个参考素材，用于生成更复杂的故事型视频。可以包含多个角色、更丰富的场景与更强的视觉连贯性。Vidu 会智能融合所有参考内容，确保不同镜头之间依然保持统一稳定的表现。\",\"title\":\"多参考支持\"},\"sameScene\":{\"description\":\"从背景到道具，整体视觉风格始终保持一致，让每个画面都更精致专业，故事表达也更加流畅自然。\",\"title\":\"场景连贯与风格统一\"},\"sameSubject\":{\"description\":\"让角色在每一帧中都保持一致的样貌与设计，动作自然流畅。借助 Vidu 的「参考生视频」功能，即使在复杂镜头中，也能始终呈现稳定统一的角色表现。\",\"title\":\"跨越不同场景，角色依然保持统一与连贯\"}},\"buttons\":{\"generateNow\":\"立即生成\"},\"comparison\":{\"columns\":{\"dimension\":\"维度\",\"imageToVideo\":\"图生视频\",\"referenceToVideo\":\"参考生视频\"},\"description\":\"如果你的重点是故事表达与画面一致性，建议使用「参考生视频」，如果只是想让单张图片或关键帧动起来，则更适合使用「图生视频」。\",\"rows\":{\"bestFor\":{\"dimension\":\"适合场景\",\"imageToVideo\":\"快速内容、产品动图、社媒短片\",\"referenceToVideo\":\"故事叙述、广告、AI 虚拟人物、多场景工作流\"},\"complexity\":{\"dimension\":\"复杂度\",\"imageToVideo\":\"低\",\"referenceToVideo\":\"中到高\"},\"consistency\":{\"dimension\":\"一致性\",\"imageToVideo\":\"有限 — 并非为多场景一致性设计\",\"referenceToVideo\":\"强 — 保持角色身份与场景连贯\"},\"controlLevel\":{\"dimension\":\"控制粒度\",\"imageToVideo\":\"中等 — 主要控制动态与画面动画\",\"referenceToVideo\":\"高 — 可控制角色、风格、构图、镜头与特效\"},\"coreUseCase\":{\"dimension\":\"核心用例\",\"imageToVideo\":\"让单张图片或首尾帧动起来\",\"referenceToVideo\":\"跨多个镜头、以一致性为核心的视频生成\"},\"inputType\":{\"dimension\":\"输入类型\",\"imageToVideo\":\"单张图片或关键帧\",\"referenceToVideo\":\"参考视频 / 多组参考（图片、视频、提示词）\"},\"output\":{\"dimension\":\"输出形式\",\"imageToVideo\":\"短片、可循环或简单动态视频\",\"referenceToVideo\":\"多镜头、剧情化、结构化视频\"}},\"title\":\"参考生视频 vs 图生视频：你的项目该怎么选？\"},\"createWithoutLimits\":{\"description\":{\"caption1\":\"@牛仔 \",\"caption2\":\"@酒吧 \",\"caption3\":\"@女郎\",\"line1\":\"坐在吧台前\",\"line2word1\":\"一位\",\"line2word2\":\"拿着一瓶红酒走向他\",\"line3\":\"镜头向前推进...\",\"total\":\"@牛仔 坐在 @酒吧 的吧台前，一位 @女郎 从右侧拿着一瓶红酒走向他，镜头向前推进...\"},\"title\":\"突破想象边界 - 参考生视频\"},\"cta\":\"立即体验参考生视频\",\"faq\":{\"q1\":{\"description\":\"「参考生视频」是一种 AI 视频生成方式，通过参考视频或图片来生成具有一致性的多镜头视频。它可以帮助你控制角色身份、画面风格、镜头运动以及场景连贯性，非常适合用于故事表达与专业内容创作。\",\"title\":\"什么是 AI 视频生成中的「参考生视频」？\"},\"q2\":{\"description\":\"两者的主要区别在于控制能力与一致性表现。「参考生视频」通过参考素材确保角色在多场景中的一致性；而「图生视频」则主要用于让单张图片动起来，动作较简单，对整体连贯性的控制相对较弱。\",\"title\":\"「参考生视频」和「图生视频」有什么区别？\"},\"q3\":{\"description\":\"想要实现稳定的角色一致性，建议使用「参考生视频」并配合清晰的参考图片或视频素材。这种方式可以帮助系统在多个镜头中保持角色、场景与整体视觉风格的统一。\",\"title\":\"如何在 AI 视频生成中保持角色一致性？\"},\"q4\":{\"description\":\"当你需要制作剧情类视频、广告内容或 AI 虚拟人物内容时，建议使用「参考生视频」并搭配参考图片，这样可以更好地保证角色一致性、场景稳定性以及多镜头叙事的连贯表达。\",\"title\":\"什么时候应该使用带参考图的「参考生视频」？\"},\"q5\":{\"description\":\"你可以将角色、风格、构图、镜头运动、场景以及特效等元素作为参考输入。这些信息可以来自图片或视频，用于引导生成过程，从而获得更稳定、更一致的最终视频效果。\",\"title\":\"在「参考生视频」中可以使用哪些参考元素？\"},\"title\":\"Vidu 参考生视频常见问题\"},\"keepConsistent\":{\"issues\":{\"continuity\":{\"description\":\"添加少量参考图片，并标注关键动作与重点信息。清晰的指引可以帮助 Vidu 更准确理解角色与物体的外观与运动方式，从而让每个场景都保持统一、自然、连贯。\",\"title\":\"如何提升画面连贯性\"},\"facesOutfits\":{\"description\":\"当同一个角色出现在多个镜头中时，如果缺少清晰的参考，其面部特征或服装可能会出现变化。通过为每个角色建立参考主体，Vidu 可以帮助保持其在整个视频中的一致性。\",\"title\":\"为什么角色在不同镜头中会\\\"变脸\\\"或换装\"},\"objects\":{\"description\":\"在缺少明确参考的情况下，画面中的物体可能会移动、消失或出现不合理的变化。通过参考视频，可以明确每个物体的位置与状态，确保所有元素在不同镜头中保持稳定一致。\",\"title\":\"为什么物体会消失或发生变化\"}},\"title\":\"保持视频一致性：常见问题与解决方法\"},\"step\":{\"step1\":{\"description\":\"进入 Vidu 官网，点击 Try Vidu，选择「参考生视频」。上传 1–7 张参考图片，可以使用自己的图片，也可以从 RefHub 素材库中直接选用。\",\"title\":\"选择「参考生视频」\"},\"step2\":{\"description\":\"在输入框中描述你希望角色或物体做什么动作，同时可以设置视频分辨率、画面比例等参数，自由调整生成效果。\",\"title\":\"输入提示词\"},\"step3\":{\"description\":\"点击 Create 开始生成视频，等待系统完成制作。生成后可先预览效果，确认无误后即可下载保存到本地设备。\",\"title\":\"生成并下载\"},\"title\":\"如何使用 Vidu 参考生视频\"},\"subtitle\":\"用参考生视频，轻松生成前后一致的 AI 视频。上传参考素材，即可让人物、物体与场景在多镜头中始终保持统一，实现自然衔接、流畅过渡。\",\"title\":\"参考生视频\",\"useCase\":{\"advertising\":{\"description\":\"借助参考图像，确保每个物体与产品在不同画面中保持高度一致。无论是形状、颜色还是纹理，都稳定如一，不会出现偏移或失真。\",\"title\":\"精准还原产品与物体细节\"},\"fun\":{\"description\":\"「参考生视频」能够延续整体视觉风格、光影氛围与场景构图，让视频叙事自然流畅，避免镜头切换带来的突兀感。\",\"title\":\"维持画面与故事的视觉连贯性\"},\"narrativeShorts\":{\"description\":\"通过「参考生视频」功能，让同一角色在不同场景与镜头中始终保持统一外观。这对于多镜头叙事或反复出现角色的动画内容尤为重要。\",\"title\":\"多镜头下角色始终一致\"},\"personalIP\":{\"description\":\"保持角色、Logo 以及品牌元素的一致性，帮助强化品牌识别度，同时更好地保护你的知识产权。\",\"title\":\"打造更可靠的品牌与 IP 内容\"},\"title\":\"用「参考生视频」实现稳定一致的 AI 视频创作\"}},\"ai-sound-effect-generator\":{\"buttons\":{\"generateNow\":\"立即生成\"},\"cta\":{\"button\":\"立即生成\",\"title\":\"Vidu AI 音效生成器\"},\"faq\":{\"q1\":{\"description\":\"Vidu AI 音效生成器通过文本提示词生成高质量音频，您可以精确控制每段音效的时长和起止时间。它还支持多段音效叠加，根据描述自动混音并输出完整音频。\",\"title\":\"AI 文本转音效生成器是如何工作的？\"},\"q2\":{\"description\":\"它非常适合为电影、游戏、视频、播客及其他创意项目生成定制音效、环境音和伴奏音乐。\",\"title\":\"文本转音频技术的主要应用场景有哪些？\"},\"q3\":{\"description\":\"是的，Vidu 所生成的音效为免版权内容，您可以自由使用，无需支付额外授权费用。\",\"title\":\"Vidu 生成的 AI 音效是否免版权？\"},\"q4\":{\"description\":\"当然可以！您可以将 Vidu 生成的音效用于广告、电影、游戏等各类商业项目中。\",\"title\":\"我可以将生成的音效用于商业项目吗？\"},\"q5\":{\"description\":\"为了获得最佳效果，建议每个时间戳使用 1 到 3 个关键声音元素，避免超过 5 个；每段音效使用 1 到 5 个重叠时间戳来实现更好的叠加效果，并将每个提示控制在 100 个字符以内。\",\"title\":\"使用 Vidu AI 音效生成器编写有效提示词有哪些最佳实践？\"},\"title\":\"常见问题 AI 音效生成器\"},\"showcase\":{\"Ambient\":{\"Knife\":\"菜刀在砧板上剁切的声音\",\"title\":\"环境音\",\"train\":\"火车鸣笛声，车轮与铁轨的摩擦声\",\"Violent\":\"猛烈撞击声，玻璃碎裂声，野兽低吼声\",\"Waves\":\"海浪拍岸声，海鸥鸣叫声，轻柔的海风声\"},\"backgroundMusic\":{\"jazz\":\"复古拉丁爵士，使用吉他、打击乐器（如康加鼓、铃鼓）、萨克斯和钢琴，节奏明快，适合热情的舞会或阳光午后的街头表演\",\"light\":\"一支悠扬纯净的长笛，旋律轻盈流动，带有自然与幻想的气息，在春日的森林场景里\",\"title\":\"背景音乐\"},\"description\":\"体验 AI 生成声音的无限可能——Vidu 可创作环境音效、背景音乐，以及精准控制时序的多层音频叠加。\",\"feature\":{\"card\":{\"card1\":{\"description\":\"在 10 秒时长内的任意时间点生成音效。Vidu 提供精细化时间控制，帮助创作者将音效精准同步到视觉内容中。\",\"title\":\"精确音效时序控制\"},\"card2\":{\"description\":\"可将多个音频片段无缝合成为一个音频文件。Vidu 支持音效堆叠和重叠，轻松构建复杂而沉浸的声音场景。\",\"title\":\"灵活的音效叠加与组合\"},\"card3\":{\"description\":\"大多数工具仅支持 16 KHz 或 32 KHz，Vidu 提供专业级的 48 KHz 音质，树立 AI 生成音效的新标杆。\",\"title\":\"48 KHz 高保真音质\"},\"card4\":{\"description\":\"Vidu 生成的音效在层次、流畅度和情绪氛围上表现更佳，是打造动态、真实声音体验的理想选择。\",\"title\":\"更丰富、更沉浸的音效细节\"}},\"description\":\"Vidu能轻松制作高品质音效，精准卡点，支持音效叠加，富有感染力，适合视频、游戏、和各种创意作品。\",\"title\":\"为何创作者选择Vidu的AI音效？\"},\"prompt\":\"提示词\",\"Timed Layers\":\"音效叠加\",\"title\":\"AI音效展示\"},\"step\":{\"step1\":{\"description\":\"打开 “AI Sound Effects” 工具，输入你的提示词（例如 “风声、脚步声”），通过时间戳精确控制每段音效的播放时间。\",\"title\":\"输入提示词 \u0026 设置时间点\"},\"step2\":{\"description\":\"选择 1–10 秒的总时长，并确保涵盖所有音效的播放时间。可添加更多时间戳，叠加多个音效图层。\",\"title\":\"设置总时长 \u0026 添加音效图层\"},\"step3\":{\"description\":\"点击 “创作” 开始生成音效。完成后可下载或分享你的专属 AI 音效。\",\"title\":\"生成 \u0026 下载\"},\"title\":\"如何用 AI 制作音效？\"},\"subtitle\":\"将文本转化为高质量音频，包括音效、环境音和器乐轨道。\",\"title\":\"AI音效生成器\"},\"ai-templates\":{\"bottomBannerTitle\":\"试试 Vidu AI 模板，轻松生成有趣且进阶的视频\",\"breadcrumbs\":{\"home\":\"首页\",\"templates\":\"模板\"},\"buttons\":{\"generateNow\":\"立即生成\"},\"subtitle\":\"探索 Vidu 的现成模板库，从精选的亲吻、拥抱等趣味视频模板中快速开始创作。\",\"title\":\"Vidu AI 视频模板\"},\"ai-text-to-video\":{\"buttons\":{\"generateNow\":\"立即生成\"},\"cta\":{\"button\":\"立即生成\",\"title\":\"从一句话，到一支电影感视频\"},\"faq\":{\"q1\":{\"description\":\"AI 文生视频是一种将文字描述直接转化为完整视频的技术。只需描述场景、动作或镜头，系统就能自动生成多镜头视频，画面流畅连贯，并自带人声与音乐等音频效果。\",\"title\":\"什么是 AI 文生视频？它是如何工作的？\"},\"q2\":{\"description\":\"当你只有一个想法时，适合使用「文生视频」，通过描述即可生成完整画面；如果你已经有图片素材，想让其动起来，则更适合使用「图生视频」。前者更适合快速创意生成，后者更适合可控、稳定的输出。\",\"title\":\"文生视频和图生视频有什么区别？该如何选择？\"},\"q3\":{\"description\":\"常见问题包括描述过于模糊、在一个场景中加入过多动作，或缺少镜头指引。建议明确主体与场景，每个镜头聚焦一个核心动作，并加入简单的镜头描述（如推进、拉近、特写），可以显著提升效果。\",\"title\":\"哪些提示词问题会导致生成效果不佳？\"},\"q4\":{\"description\":\"文生视频可以生成电影感场景、角色动画、产品展示以及剧情类内容。从简单想法到详细描述，都可以一次性生成包含画面、动作与声音的完整视频。\",\"title\":\"文生视频可以生成哪些内容？\"},\"q5\":{\"description\":\"建议按照「主体 + 动作 + 镜头 + 场景 + 风格」的结构来组织提示词。描述越清晰具体，生成的画面越准确，动作也会更加自然流畅，整体叙事更完整。\",\"title\":\"如何写出更好的文生视频提示词？\"},\"q6\":{\"description\":\"AI 文生视频无需拍摄或剪辑，就能快速生成视频内容，大幅提升创作效率。它可以帮助你快速验证创意、缩短制作周期，并以更低成本完成高质量视频产出。\",\"title\":\"为什么选择 AI 文生视频，而不是传统视频制作工具？\"},\"title\":\"文生视频常见问题解答\"},\"feature\":{\"2DAnimation\":{\"description\":\"Vidu 作为新一代文生视频工具，带来稳定细腻的画面表现与自然流畅的角色动作。它不仅能生成清晰、丰富的画面细节，还能让创意以更具电影感的方式呈现。尤其在 2D 风格上，Vidu 不只是一个视频生成工具，更像你的动画创作伙伴。\",\"title\":\"出色的 2D 动画表现力\"},\"lightningFast\":{\"description\":\"通过 AI 文生视频，把脑海中的画面快速变成真实影像。无论是场景、氛围还是镜头运动，只需简单描述，系统就能自动生成多镜头视频，画面自然衔接，并配有声音（如人声与音乐）。整体效果稳定一致，几秒即可得到可直接使用的成片。\",\"title\":\"极速生成，一步成片\"},\"RealisticAnimation\":{\"description\":\"每一帧都拥有顺滑、真实的运动效果。无论是角色动作还是镜头变化，Vidu 都能很好地还原自然的动态节奏，让生成的视频更具沉浸感，适用于角色动画到电影级片段的多种创作场景。\",\"title\":\"自然流畅的动态表现\"},\"Stunning\":{\"description\":\"Vidu 让文生视频拥有更出色的视觉表现力。通过细腻的细节刻画、真实的材质表现与空间层次感，把简单的文字转化为更有冲击力的视频内容。不只是生成视频，更是在创造具有表现力的动态画面。\",\"title\":\"更具质感的视觉呈现\"}},\"promptFormula\":{\"items\":{\"action\":{\"description\":\"描述正在发生的事情，比如\\\"在街上行走\\\"\\\"高速行驶\\\"或\\\"对着镜头说话\\\"。动作越清晰，生成的视频就越自然流畅。\",\"title\":\"动作\"},\"camera\":{\"description\":\"设定画面呈现方式，比如\\\"特写\\\"\\\"远景\\\"或\\\"缓慢横移\\\"。也可以说明镜头运动方式，例如\\\"从背后跟拍\\\"。\",\"title\":\"镜头\"},\"scene\":{\"description\":\"交代环境背景，比如\\\"日落海滩\\\"\\\"繁忙的城市街道\\\"或\\\"柔光下的现代办公室\\\"，让画面更有真实感和氛围感。\",\"title\":\"场景\"},\"style\":{\"description\":\"选择整体风格，如\\\"电影感\\\"\\\"动漫风\\\"或\\\"写实风\\\"。也可以加入情绪或氛围描述，比如\\\"温暖\\\"\\\"暗调\\\"或\\\"柔和光线\\\"。\",\"title\":\"风格\"},\"subject\":{\"description\":\"先确定画面中出现的人或物，比如\\\"一个年轻女生\\\"或\\\"一辆红色跑车\\\"。可以补充一些细节，如服装、颜色或风格，让画面更贴近你的预期。\",\"title\":\"主体\"}},\"subtitle\":\"Turn any idea into a clear, structured prompt for better AI video results. Follow this simple formula to create more consistent, cinematic videos every time.\",\"title\":\"简单好用的提示词公式\"},\"step\":{\"step1\":{\"description\":\"点击右上角的 Try Vidu，选择「文生视频」，即可开始体验。你也可以进入 Explore 或 Template 页面获取灵感，快速上手创作。\",\"title\":\"选择「文生视频」功能\"},\"step2\":{\"description\":\"在输入框中写下你想要呈现的内容，可以描述风格、镜头或画面细节。提示词越清晰，生成的视频效果就越接近你的预期。\",\"title\":\"输入提示词\"},\"step3\":{\"description\":\"在生成前可根据需要调整参数，如风格、生成数量或画面比例等。设置完成后点击 Create，即可开始生成视频。\",\"title\":\"生成视频\"},\"title\":\"如何通过文本生成视频\"},\"subtitle\":\"用 AI 文生视频，把你的想法直接变成视频。只需输入一句描述，就能生成完整画面，动作流畅、场景连贯，无需剪辑，也无需反复尝试。\",\"title\":\"AI 文生视频\"},\"api-platform\":\"API开放平台\",\"app\":{\"cameraPermission\":\"No album access. Enable it in system settings.\"},\"blog\":{\"blog\":\"Vidu 博客\",\"breadcrumbs\":{\"blog\":\"博客\",\"home\":\"首页\"},\"description\":\"探索 Vidu 博客，获取 AI 视频创作的专家技巧、趋势洞察和教程，及时了解 AI 视频技术的最新动态。\",\"noPosts\":\"未找到博客文章。\",\"search\":{\"button\":\"搜索\",\"placeholder\":\"在这里搜索\"},\"section\":{\"latest\":\"最新{title}文章\"},\"slug\":{\"conclusion\":\"结论\",\"createButton\":{\"button\":\"立即创作\",\"description\":\"出色的 AI 视频生成器，可在数秒内生成高质量结果。\"}},\"title\":\"Vidu 博客 - AI 视频创作洞察与技巧\",\"viewAll\":\"查看全部\"},\"bonusCode\":{\"dialog\":{\"error\":\"福利码错误/失效\",\"errorUserHasSubscriptions\":\"您已经订阅过套餐，不能再享受首次订阅福利\",\"placeholder\":\"请填写福利码\",\"submit\":\"提交\",\"success\":\"成功\",\"title\":\"福利码\"},\"entry\":{\"clear\":\"清除\",\"reSubmit\":\"修改\",\"submit\":\"立刻填写\",\"tips\":\"输入福利码，订阅可获额外积分奖励。\\n福利码由创作者、KOL或合作伙伴在社交平台或群聊中发布，好友与粉丝均可获取。\",\"title\":\"使用福利码进行首次订阅，获得额外积分。与首次订阅折扣不同享\",\"used\":\"已使用福利码：{code}\"}},\"CharImgCropModal\":{\"description\":\"图片限制：最大50MB、最小面积128x128，宽高比最大4:1\",\"title\":\"图片编辑\"},\"claw\":{\"applyDialog\":{\"clawAlreadyActiveError\":\"Claw 已激活，请勿重复激活\",\"clawCodeAlreadyBound\":\"ClawCode 已绑定，请勿重复绑定\",\"clawCodeInvalid\":\"ClawCode 无效，请输入正确的 ClawCode\",\"clawInProgressError\":\"Claw 正在创建中，预估时间 10 分钟，请稍后再试\",\"hint\":\"如果您还未拥有 ClawCode，您可以通过 \u003cspan\u003e点击此处\u003c/span\u003e 申请ClawCode\",\"submitError\":\"请输入正确的 ClawCode\",\"title\":\"请输入 ClawCode 激活\",\"upgrade\":\"或升级会员立即开通 ViduClaw \u003cspan\u003e立即升级\u003c/span\u003e\"},\"assets\":{\"actions\":{\"delete\":\"删除\",\"download\":\"下载\",\"insert\":\"以 @ 引用到当前输入框\",\"share\":\"分享\"},\"deleteConfirm\":\"确认从当前 Claw 中删除这个资产吗？\",\"empty\":\"当前目录还没有内容\",\"emptyDescription\":\"上传文件或新建文件夹后，这里会展示当前目录下的资源。\",\"emptyFolders\":\"当前目录还没有文件夹