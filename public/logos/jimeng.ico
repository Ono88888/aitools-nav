io_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1810820137\u0026x-signature=ZmvLFwvuJkgJMSMjsFsFnn6v2N8%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"电影感情绪大片 · 视觉叙事摄影提示词（精简优化版）\n \n金奖级艺术人像，电影关键帧质感，前卫时尚情绪大片\n \n整体风格\n \n电影摄影美学，非对称构图，虚实重叠，迷离弱印象风；\n低光清冷主调，斑驳局部暖光对比，强烈光影故事感；\n高胶片粗颗粒质感，泛朦柔光，可控过曝，高级清冷氛围感。\n \n镜头与构图\n \n电影级长焦镜头，极致空间压缩，梦幻浅景深层次；\n写意非对称构图，精准对焦主体，前景背景模糊人影动态互动，叙事张力拉满。\n \n人物与细节\n \n韩系质感秀发，发丝光泽灵动，前卫潮流穿搭；\n自然动态抓拍姿态，主体眼神、服饰纹理极致清晰；\n与模糊环境、噪点质感形成强烈对比，视觉焦点突出。\n \n氛围与质感\n \n前卫艺术气息，高级叙事感，电影级画面，极具视觉冲击力；\n极小白色英文主题词，贴合画面意境。","seed":93204321,"large_image_info":{"height":1472,"width":1104,"resolution_type":"1k"},"sample_strength":0.3,"use_pe":true,"schedule_conf":"std","actual_prompt":"电影感情绪大片 · 视觉叙事摄影提示词（精简优化版）\n \n金奖级艺术人像，电影关键帧质感，前卫时尚情绪大片\n \n整体风格\n \n电影摄影美学，非对称构图，虚实重叠，迷离弱印象风；\n低光清冷主调，斑驳局部暖光对比，强烈光影故事感；\n高胶片粗颗粒质感，泛朦柔光，可控过曝，高级清冷氛围感。\n \n镜头与构图\n \n电影级长焦镜头，极致空间压缩，梦幻浅景深层次；\n写意非对称构图，精准对焦主体，前景背景模糊人影动态互动，叙事张力拉满。\n \n人物与细节\n \n韩系质感秀发，发丝光泽灵动，前卫潮流穿搭；\n自然动态抓拍姿态，主体眼神、服饰纹理极致清晰；\n与模糊环境、噪点质感形成强烈对比，视觉焦点突出。\n \n氛围与质感\n \n前卫艺术气息，高级叙事感，电影级画面，极具视觉冲击力；\n极小白色英文主题词，贴合画面意境。","model_rewritten_prompt":"电影摄影美学，非对称构图，虚实重叠，低光清冷主调，斑驳局部暖光对比，高胶片粗颗粒质感，泛朦柔光，过曝，韩系质感秀发，发丝光泽灵动，前卫潮流穿搭，主体眼神、服饰纹理极致清晰，写意，极致空间压缩，梦幻浅景深层次，前卫艺术气息，高级叙事感，极小白色英文主题词，贴合画面意境，电影级长焦镜头，精准对焦主体，前景背景模糊人影动态互动，强烈光影故事感，迷离弱印象风，极小白色英文主题词，贴合画面意境。"},"template_id":"7612816382178168073","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false},"statistic":{"usage_num":438,"favorite_num":507,"play_num":0},"category_id_list":[12064],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7612816382178168073","effect_id":"7612816382178168073","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/8