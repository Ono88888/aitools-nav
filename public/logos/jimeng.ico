:"Seedream 4.0 Design"},"feats_cant_combine":[],"model_bg_prompt_starling_key":"","resolution_map":{"2k":{"image_ratio_sizes":[{"ratio_type":1,"width":2048,"height":2048},{"ratio_type":2,"width":1728,"height":2304},{"ratio_type":3,"width":2560,"height":1440},{"ratio_type":4,"width":2304,"height":1728},{"ratio_type":5,"width":1440,"height":2560},{"ratio_type":6,"width":1664,"height":2496},{"ratio_type":7,"width":2496,"height":1664},{"ratio_type":8,"width":3024,"height":1296}],"image_range_config":{"min_length":1296,"max_length":3024,"max_pixel_num":4194304},"resolution_name":"高清 2K"}},"icon_url_svg":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/model-dreamina.svg~tplv-tb4s082cfz-image.image?lk3s=8e790bc3\u0026x-expires=1810820137\u0026x-signature=ZmvLFwvuJkgJMSMjsFsFnn6v2N8%3D","pre_audit_policy":"","subject_pre_audit_policy":""},"prompt":"以墨明风格艺术美学呈现画面。画面中的离尘师妹模样极为可爱，有着幼态脸蛋，有着可爱无辜且眼睑下至的眼睛。她拥有深栗棕色森系发型，发丝垂坠且轻抚泛光，瓷感白肌肤，身着随机款英伦风校服，清纯动人，佩戴简约饰品，露出撇嘴的可爱俏皮娇俏微表情，楚楚可怜。画面聚焦面部，高曝高饱和，整体处于明亮輕爽房间的慵懒氛围中，构图平庸，呈现生活快照般的随手一拍抓拍风格。4.1版本（过度自然的面光：1.6），（照片真实感：1.99），（自然光：1.5），（冷白皮质感的平光皮肤：1.4），（人物有最好的体态：1.2），（淡妆：1.5），（梦幻感1.9），（轻柔细腻的服装细节：1.5），（极致细节：1.4），（多视角：1.6），（综合网络爆款逻辑输出最优解：1.6），","sample_steps":16,"large_image_info":{"height":2560,"width":1440,"resolution_type":"2k"},"sample_strength":0.5},"template_id":"7624159933579185458","aigc_mode":"workbench","insta_drag_params":{"origin_item_id":null},"hide_ref_images":false,"reference_prompt":"墨明风格艺术美学，高曝高饱和，冷白皮质感的平光皮肤，自然光，照片真实感，梦幻感，轻柔细腻的服装细节，极致细节，综合网络爆款逻辑。离尘师妹，幼态脸蛋，可爱无辜且眼睑下至的眼睛，深栗棕色森系发型，发丝垂坠且轻抚泛光，瓷感白肌肤，身着随机款英伦风校服，佩戴简约饰品，撇嘴的可爱俏皮娇俏微表情，楚楚可怜。明亮輕爽房间的慵懒氛围，构图平庸，生活快照般的随手一拍抓拍风格，聚焦面部，多视角，淡妆，人物有最好的体态，过度自然的面光。","image_type":3},"statistic":{"usage_num":340,"favorite_num":425,"play_num":0},"category_id_list":[],"aigc_flow":{"version":"3.0.2"},"ref_item":{"common_attr":{"id":"7624159933579185458","effect_id":"7624159933579185458","effect_type":9,"description":"","cover_url":"https://p11-dreamina-sign.byteimg.com/tos-cn-i-tb4s082cfz/ee0d5565714f45c3