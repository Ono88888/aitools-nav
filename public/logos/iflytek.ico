}
.plugin-login-container {
  position: absolute;
  z-index: 10000;
  width: 380px;
  height: auto;
  min-height: 459px;
  background: #ffffff;
  box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.1);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
